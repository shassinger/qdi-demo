{
  "name": "QDI Sandbox",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",
  "postCreateCommand": "./scripts/bootstrap",
  "postStartCommand": "QDI_SKIP_BOOTSTRAP=1 ./scripts/start --background",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "QDI Demo",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["qdi-core/python/index.html"]
    }
  }
}
