{
  "name": "QDI Sandbox",
  "image": "mcr.microsoft.com/devcontainers/python:3.10-bullseye",
  "postCreateCommand": "python3 -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install fastapi uvicorn httpx qiskit qiskit-aer || echo 'resilient_install'",
  "postStartCommand": "bash .devcontainer/start.sh",
  "forwardPorts": [8000, 3000],
  "portsAttributes": {
    "8000": {
      "label": "QDI Backend API",
      "onAutoForward": "silent",
      "visibility": "public"
    },
    "3000": {
      "label": "QDI Web Console",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "customizations": {
    "codespaces": {
      "openFiles": ["qdi-core/python/index.html"]
    }
  }
}
