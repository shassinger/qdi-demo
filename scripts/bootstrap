#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

PYTHON_BIN="${QDI_PYTHON:-python3}"
if ! command -v "$PYTHON_BIN" >/dev/null 2>&1; then
    echo "Python 3.11 or newer is required (tried: $PYTHON_BIN)." >&2
    exit 1
fi

if ! "$PYTHON_BIN" -c 'import sys; raise SystemExit(sys.version_info < (3, 11))'; then
    echo "Python 3.11 or newer is required." >&2
    exit 1
fi

if [ ! -x .venv/bin/python ]; then
    echo "Creating .venv with $PYTHON_BIN..."
    "$PYTHON_BIN" -m venv .venv
fi

requirements_fingerprint="$(cksum requirements.txt)"
requirements_stamp=".venv/.qdi-requirements"
installed_fingerprint=""
if [ -f "$requirements_stamp" ]; then
    installed_fingerprint="$(<"$requirements_stamp")"
fi

if [ "$requirements_fingerprint" != "$installed_fingerprint" ]; then
    echo "Installing pinned Python dependencies..."
    .venv/bin/python -m pip install --disable-pip-version-check -r requirements.txt
    printf '%s\n' "$requirements_fingerprint" > "$requirements_stamp"
else
    echo "Python dependencies are current."
fi

compiler=""
for candidate in c++ clang++ g++; do
    if command -v "$candidate" >/dev/null 2>&1; then
        compiler="$candidate"
        break
    fi
done

if [ -z "$compiler" ]; then
    echo "A C++17 compiler is required (c++, clang++, or g++)." >&2
    exit 1
fi

case "$(uname -s)" in
    Darwin)
        library="qdi-core/libqdi_mock.dylib"
        link_flag="-dynamiclib"
        ;;
    Linux)
        library="qdi-core/libqdi_mock.so"
        link_flag="-shared"
        ;;
    *)
        echo "Unsupported operating system: $(uname -s). Use macOS or Linux." >&2
        exit 1
        ;;
esac

echo "Building $library with $compiler..."
"$compiler" "$link_flag" -o "$library" \
    -Iqdi-core/include qdi-core/src/qdi_mock.cpp -std=c++17 -fPIC

echo "QDI demo bootstrap complete."
